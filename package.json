{
  "name": "harness-os",
  "version": "1.0.0",
  "description": "Harness OS - Codex-first Project Operating System",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.3",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --dts --clean --out-dir dist && node -e \"require('fs').cpSync('templates','dist/templates',{recursive:true})\"",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build && pnpm test --run",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "harness": "./dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "pino": "^10.3.1",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
